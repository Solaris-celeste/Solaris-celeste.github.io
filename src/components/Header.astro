---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200">
<div class="max-w-3xl mx-auto px-6 h-16 flex items-center justify-between">
<h2 class="text-lg font-semibold text-slate-900 tracking-tight">
<a href="/" class="hover:text-blue-600 transition-colors">{SITE_TITLE}</a>
</h2>
<nav class="flex items-center gap-6 text-sm font-medium text-slate-600">
<HeaderLink href="/" class="hover:text-blue-600 transition-colors">首页</HeaderLink>
<HeaderLink href="/blog" class="hover:text-blue-600 transition-colors">博客</HeaderLink>
<HeaderLink href="/about" class="hover:text-blue-600 transition-colors">关于</HeaderLink>
</nav>
</div>
</header>
